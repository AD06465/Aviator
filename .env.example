# Application Environment Variables
# Copy this file to .env.local and configure for your environment

# Application Settings
NEXT_PUBLIC_APP_NAME=AVIATOR
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_ENV=development

# Logging
NEXT_PUBLIC_LOG_LEVEL=1
# Log Levels: 0=DEBUG, 1=INFO, 2=WARN, 3=ERROR, 4=CRITICAL

# API Configuration
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_RETRY_ATTEMPTS=3
NEXT_PUBLIC_MONITORING_INTERVAL=30000

# Feature Flags
NEXT_PUBLIC_FEATURE_AUTO_RETRY=true
NEXT_PUBLIC_FEATURE_PARALLEL_PROCESSING=false
NEXT_PUBLIC_FEATURE_ADVANCED_LOGGING=true
NEXT_PUBLIC_FEATURE_ERROR_REPORTING=false

# Default Environment (Test 1, Test 2, or Test 4)
NEXT_PUBLIC_DEFAULT_ENVIRONMENT=Test 1

# Storage
NEXT_PUBLIC_STORAGE_PREFIX=aviator
